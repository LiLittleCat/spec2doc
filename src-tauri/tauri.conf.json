{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Spec2Doc",
  "version": "0.0.1",
  "identifier": "do.yl.spec2doc",
  "build": {
    "beforeDevCommand": "pnpm dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "pnpm build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "Spec2Doc",
        "width": 1200,
        "height": 800,
        "minWidth": 800,
        "minHeight": 600
      }
    ],
    "security": {
      "csp": null
    }
  },
  "plugins": {
    "updater": {
      "endpoints": ["https://github.com/LiLittleCat/spec2doc/releases/latest/download/latest.json"],
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDBEQTM4RjkxRDQyNUZFNjYKUldSbS9pWFVrWStqRGRuQk5SdW5MQ3dmWGVoM0U5RXpWS3loNHhaU3k5YXFESVV0QWEvZ3pJR2cK"
    }
  },
  "bundle": {
    "active": true,
    "targets": ["nsis"],
    "resources": {
      "../assets/接口文档模板.docx": "接口文档模板.docx",
      "../assets/数据库设计文档模板.docx": "数据库设计文档模板.docx"
    },
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
